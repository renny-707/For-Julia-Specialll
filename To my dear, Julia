<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <title>For My Pink Lily</title>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Poppins:wght@400;600&family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #fff0f5 0%, #f8bbd9 25%, #e1bee7 50%, #fce4ec 75%, #f3e5f5 100%);
            font-family: 'Quicksand', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* Lily Melayang di Background */
        .floating-lily {
            position: fixed;
            pointer-events: none;
            z-index: 1;
            opacity: 0.5;
            animation: float 25s infinite linear;
            bottom: -100px;
        }

        @keyframes float {
            0% { transform: translateY(0) rotate(0deg); opacity: 0; }
            10% { opacity: 0.7; }
            90% { opacity: 0.7; }
            100% { transform: translateY(-120vh) rotate(720deg); opacity: 0; }
        }

        #container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 50px 30px;
            border-radius: 40px;
            box-shadow: 
                0 25px 70px rgba(255, 182, 193, 0.5),
                0 0 0 3px rgba(255, 192, 203, 0.4);
            width: 100%;
            max-width: 550px;
            position: relative;
            z-index: 10;
        }

        /* PAGE 1 */
        #page1 h1 {
            font-family: 'Dancing Script', cursive;
            background: linear-gradient(45deg, #9c27b0, #e91e63, #ff4081);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: clamp(2.5rem, 8vw, 3.8rem);
            margin-bottom: 40px;
            text-shadow: 0 5px 15px rgba(233, 30, 99, 0.2);
        }

        .btn-group {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-top: 20px;
        }

        button {
            padding: 18px 40px;
            font-size: 1.2rem;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            border: none;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        #yesBtn {
            background: linear-gradient(45deg, #ff80ab, #ff4081, #f50057);
            color: white;
            min-width: 150px;
        }

        #yesBtn:hover {
            transform: translateY(-5px) scale(1.1);
            box-shadow: 0 15px 35px rgba(255, 128, 171, 0.7);
        }

        #noBtn {
            background: #f3e5f5;
            color: #7b1fa2;
            min-width: 130px;
        }

        /* PAGE 2 - LOVE LETTER */
        .hidden { display: none; }

        #page2 {
            max-height: 80vh;
            overflow-y: auto;
            padding: 10px;
            scrollbar-width: none;
        }
        
        #page2::-webkit-scrollbar { display: none; }

        #page2 h1 {
            font-family: 'Dancing Script', cursive;
            color: #e91e63;
            font-size: 2.5rem;
            margin-bottom: 25px;
            text-shadow: 0 5px 15px rgba(233, 30, 99, 0.3);
        }

        .love-letter {
            color: #4a2c4a;
            font-size: 1.05rem;
            line-height: 1.9;
            padding: 40px 25px;
            text-align: left;
            background: linear-gradient(135deg, rgba(255, 248, 250, 0.9), rgba(248, 220, 232, 0.8));
            border-radius: 30px;
            border: 1px solid rgba(233, 30, 99, 0.15);
            box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.5);
            margin-bottom: 30px;
            position: relative;
        }

        .love-letter::before {
            content: '💌';
            position: absolute;
            top: -20px;
            left: 20px;
            font-size: 2rem;
        }

        .highlight {
            background: linear-gradient(120deg, #fce4ec 0%, #f8bbd9 100%);
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 700;
            color: #c2185b;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.05);
        }

        .closing {
            font-family: 'Dancing Script', cursive;
            font-size: 1.6rem;
            color: #e91e63;
            margin-top: 25px;
            font-weight: bold;
        }

        /* Hujan Hati */
        .heart {
            position: fixed;
            pointer-events: none;
            z-index: 20;
            animation: fall linear forwards;
        }

        @keyframes fall {
            to {
                transform: translateY(110vh) rotate(720deg);
                opacity: 0;
            }
        }

        @media (max-width: 480px) {
            #container { padding: 30px 20px; }
            .btn-group { flex-direction: column; align-items: center; }
            #page2 h1 { font-size: 2rem; }
        }
    </style>
</head>
<body>

    <div class="floating-lily" style="left: 5%; animation-delay: 0s; font-size: 45px;">🌸</div>
    <div class="floating-lily" style="left: 20%; animation-delay: 8s; font-size: 30px;">🌺</div>
    <div class="floating-lily" style="left: 75%; animation-delay: 4s; font-size: 40px;">🌸</div>
    <div class="floating-lily" style="left: 90%; animation-delay: 12s; font-size: 35px;">🌺</div>

    <div id="container">
        <div id="page1">
            <h1>My Dear Julia... 💕</h1>
            <div class="btn-group">
                <button id="yesBtn" onclick="showPage2()">Yes! 💖</button>
                <button id="noBtn" onmouseover="moveNoButton()">No 😅</button>
            </div>
        </div>

        <div id="page2" class="hidden">
            <h1>Julia, My Pink Lily... 🌸</h1>
            <div class="love-letter">
                <p>Julia sayang... Kamu tahu nggak? Kadang aku cuma bisa diam sambil perhatiin kamu, terus mikir sendiri, <i>"Gimana bisa ada orang seindah ini di hidupku?"</i>. Kalau dunia ini adalah sebuah taman, kamu itu <span class="highlight">Pink Lily</span> yang paling bersinar—nggak perlu berusaha keras buat narik perhatian, karena keanggunan dan ketulusanmu itu terpancar dengan sendirinya.</p>
                
                <br>

                <p>Aku suka banget setiap detail kecil tentang kamu. Cara mata kamu berbinar pas lagi cerita hal yang kamu suka, cara kamu panggil namaku yang selalu berhasil bikin jantungku telat satu detak, sampai cara kamu kasih perhatian-perhatian kecil yang mungkin kamu anggap biasa, tapi buat aku itu segalanya. Kamu itu kombinasi sempurna antara warna pink yang lembut dan putih yang suci; menenangkan sekaligus bikin aku kagum nggak habis-habis.</p>
                
                <br>

                <p>Bersama kamu, waktu rasanya kayak berhenti tapi juga jalan terlalu cepat. Aku pengen jadi orang yang selalu ada di barisan paling depan buat dukung semua mimpi-mimpimu. Aku pengen jadi rumah tempat kamu pulang pas kamu capek, jadi pelukan yang paling hangat pas kamu sedih, dan jadi alasan kenapa kamu tersenyum setiap pagi bangun tidur.</p>
                
                <br>

                <p>Julia, terima kasih sudah lahir ke dunia ini dan membiarkan aku jadi bagian dari hidupmu. Aku janji nggak cuma bakal sayang kamu pas lagi bahagia aja, tapi aku bakal genggam tanganmu lebih erat lagi pas keadaan lagi sulit. Kamu itu bukan cuma sekadar pacar buat aku, tapi kamu adalah <span class="highlight">pusat dari duniaku</span> sekarang dan selamanya.</p>
                
                <br>

                <p>Tetap jadi Julia yang aku kenal ya? Yang lembut, yang hebat, dan yang selalu bisa bikin aku jatuh cinta berkali-kali setiap harinya. I’m so deeply, madly, and forever in love with you, my beautiful Lily.</p>
            </div>
            
            <div class="closing">
                I Love You More Than Words Can Say, Julia 💕
                <br>
                <small style="font-family: 'Poppins'; font-size: 0.9rem; color: #7b1fa2; opacity: 0.8; font-weight: 400;">
                    Forever yours...
                </small>
            </div>
        </div>
    </div>

    <script>
        // Fungsi biar tombol "No" lari-larian
        function moveNoButton() {
            const btn = document.getElementById('noBtn');
            const x = Math.random() * (window.innerWidth - btn.offsetWidth);
            const y = Math.random() * (window.innerHeight - btn.offsetHeight);
            
            btn.style.position = 'fixed';
            btn.style.left = x + 'px';
            btn.style.top = y + 'px';
            btn.style.zIndex = '1000';
        }

        // Fungsi pindah halaman dan munculin hujan hati
        function showPage2() {
            document.getElementById('page1').classList.add('hidden');
            document.getElementById('page2').classList.remove('hidden');
            
            // Efek hujan hati berkelanjutan
            setInterval(createHeart, 250);
            
            // Tambahin bunga melayang ekstra pas klik "Yes"
            for(let i = 0; i < 10; i++) {
                setTimeout(createFloatingLily, i * 200);
            }
        }

        function createHeart() {
            const heart = document.createElement('div');
            heart.className = 'heart';
            const emojis = ['💕', '🌸', '💖', '✨', '🌺', '💝', '🌹'];
            heart.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.top = '-20px';
            heart.style.fontSize = (Math.random() * 20 + 20) + 'px';
            heart.style.animationDuration = (Math.random() * 3 + 2) + 's';
            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 5000);
        }

        function createFloatingLily() {
            const lily = document.createElement('div');
            lily.className = 'floating-lily';
            lily.innerHTML = Math.random() > 0.5 ? '🌸' : '🌺';
            lily.style.left = Math.random() * 100 + '%';
            lily.style.animationDuration = (Math.random() * 10 + 15) + 's';
            lily.style.fontSize = (Math.random() * 20 + 25) + 'px';
            document.body.appendChild(lily);
        }
  
  </script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
